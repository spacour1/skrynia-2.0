# Backend API base URL. Next.js rewrites /api/* -> this address server-side.
# Under docker-compose, the frontend container uses http://backend:4000 (not localhost).
NEXT_PUBLIC_API_URL=http://localhost:4000

# WebSocket URL — browser-side, always the public/host-facing address.
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# Canonical public URL of the frontend — used for metadataBase, sitemap, Open Graph.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shows the dev/test payment panel on the order page even on a production build.
# Only works if backend's ENABLE_TEST_PAYMENTS is also set. Leave false on real production.
NEXT_PUBLIC_ENABLE_TEST_PAYMENTS=false

# Sentry error tracking — leave unset to disable (no overhead in CI/local dev).
# Get the DSN from https://sentry.io → Project Settings → Client Keys.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<host>/0
# Build-time only (not shipped to browser):
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=skrynia-frontend
# SENTRY_AUTH_TOKEN=        # required for source map upload to Sentry

# PostHog product analytics — leave unset to disable entirely.
# Get the project API key from https://app.posthog.com → Project Settings.
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com   # EU cloud; use https://app.posthog.com for US
