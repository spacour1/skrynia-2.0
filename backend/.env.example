NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://marketplace:marketplace@localhost:5432/marketplace
REDIS_URL=redis://localhost:6379

# PostgreSQL connection pool — default 20 is fine for a single dev/staging instance.
# In production: set to (total_pg_connections_available / number_of_api_replicas).
# Rule of thumb: 5–10 per API replica behind PgBouncer, 10–20 for direct connections.
# Warning: backend_instances × PG_POOL_MAX must stay below PostgreSQL's max_connections.
PG_POOL_MAX=20

JWT_SECRET=dev-secret-change-me-for-local-work
# 32-byte AES key encoded as 64 hexadecimal characters. Generate a unique production
# value with: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
TWO_FACTOR_ENCRYPTION_KEY=6465762d74776f2d666163746f722d656e6372797074696f6e2d6b65792d3031
TWO_FACTOR_ENCRYPTION_KEY_VERSION=1
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
FRONTEND_URL=http://localhost:3000
# Comma-separated extra origins allowed to open WebSocket connections (besides FRONTEND_URL)
ADDITIONAL_ALLOWED_ORIGINS=
PUBLIC_BACKEND_URL=http://localhost:4000
PLATFORM_FEE_BPS=1000
AUTO_RELEASE_HOURS=72

# Storage: "local" (dev) or "s3" (production — Cloudflare R2, AWS S3, or any S3-compatible).
# For multi-replica production deployments, local storage will not be shared between replicas.
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=uploads
MEDIA_PUBLIC_BASE_URL=http://localhost:4000/uploads
STORAGE_TEMP_TTL_HOURS=24
STORAGE_MAX_IMAGE_WIDTH=8192
STORAGE_MAX_IMAGE_HEIGHT=8192
STORAGE_MAX_IMAGE_PIXELS=40000000
# Per-user upload abuse ceilings
STORAGE_DAILY_UPLOAD_BYTES_PER_USER=104857600
STORAGE_TOTAL_QUOTA_BYTES_PER_USER=524288000
STORAGE_MAX_OBJECTS_PER_PURPOSE=500
STORAGE_MAX_CONCURRENT_PROCESSING=4
STORAGE_PROCESSING_QUEUE_LIMIT=16
UPLOAD_RATE_LIMIT_PER_MIN=20
UPLOAD_RATE_LIMIT_PER_IP=60
# Required when STORAGE_DRIVER=s3:
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com   # R2 example; omit for AWS S3
# S3_BUCKET=skrynia-uploads
# S3_REGION=auto                                               # "auto" for R2, real region for AWS
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Job worker — set false on API-only replicas; run exactly one dedicated worker replica.
JOB_WORKER_ENABLED=true

# Durable PostgreSQL outbox. Defaults to JOB_WORKER_ENABLED when omitted.
OUTBOX_WORKER_ENABLED=true
# OUTBOX_POLL_INTERVAL_MS=1000
# OUTBOX_BATCH_SIZE=25
# OUTBOX_CONCURRENCY=5
# OUTBOX_MAX_ATTEMPTS=8
# OUTBOX_BASE_BACKOFF_MS=1000
# OUTBOX_LOCK_TIMEOUT_MS=300000
# OUTBOX_DELIVERY_TIMEOUT_MS=5000

# Reverse-proxy trust: number of proxy hops to trust for X-Forwarded-For.
# Set TRUST_PROXY=1 behind Railway / Fly.io / Cloudflare so req.ip resolves to the real
# client IP instead of the proxy address. Without this, all traffic from behind the proxy
# shares one rate-limit bucket and every user will get throttled together.
# TRUST_PROXY=1

# Rate limits (Redis-backed when REDIS_URL is configured).
# PUBLIC_READ_RATE_LIMIT_PER_MIN=600
# ANONYMOUS_WRITE_RATE_LIMIT_PER_MIN=60
# CREDENTIAL_RATE_LIMIT_PER_15MIN=20
# CREDENTIAL_RATE_LIMIT_PER_IDENTITY_15MIN=20
# AUTHENTICATED_WRITE_RATE_LIMIT_PER_MIN=60
# AUTHENTICATED_WRITE_RATE_LIMIT_PER_IP=300
# WS_TICKET_RATE_LIMIT_PER_MIN=30
# WS_TICKET_RATE_LIMIT_PER_IP=120
# WS_MAX_BUFFERED_BYTES=1048576
# WS_MAX_ROOMS_PER_CONNECTION=50
# REALTIME_CHANNEL=skrynia:realtime:v1
# REALTIME_INSTANCE_ID=optional-unique-replica-id
# PRESENCE_TTL_MS=90000
# PRESENCE_HEARTBEAT_MS=30000
# PHONE_OTP_RATE_LIMIT_PER_15MIN=10
# PHONE_OTP_RATE_LIMIT_PER_IP_15MIN=30
# EMAIL_VERIFICATION_RATE_LIMIT_PER_15MIN=10
# EMAIL_VERIFICATION_RATE_LIMIT_PER_IP_15MIN=30
# PASSWORD_RESET_RATE_LIMIT_PER_15MIN=10
# PASSWORD_RESET_RATE_LIMIT_PER_IP_15MIN=30
# WEBHOOK_RATE_LIMIT_PER_MIN=60

# Error tracking (Sentry). Leave unset to disable — the server starts fine without it.
# SENTRY_DSN=https://<key>@<host>/0
# SENTRY_RELEASE=                  # auto-detected from GITHUB_SHA / RAILWAY_DEPLOYMENT_ID
# SENTRY_TRACES_SAMPLE_RATE=0.1   # 0–1; 0.1 recommended for production

# Prometheus metrics endpoint basic auth
METRICS_USER=metrics
METRICS_PASSWORD=change-me-metrics-password

# Payment providers (at least one required in production)
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=
LIQPAY_SERVER_URL=http://localhost:4000/payments/liqpay/callback
MONOBANK_TOKEN=
MONOBANK_WEBHOOK_URL=http://localhost:4000/payments/monobank/callback
MANUAL_PAYMENT_CARD_NUMBER=
MANUAL_PAYMENT_RECEIVER_NAME=
MANUAL_PAYMENT_BANK=
WAYFORPAY_MERCHANT_ACCOUNT=
WAYFORPAY_MERCHANT_SECRET_KEY=
WAYFORPAY_SERVICE_URL=http://localhost:4000/payments/wayforpay/callback

# Telegram (optional — disables Telegram login widget and bot notifications if unset)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=skrynia_bot
# TELEGRAM_WEBHOOK_SECRET=

# Email via Resend (optional — email verification and password-reset silently no-op without it)
# RESEND_API_KEY=
# EMAIL_FROM=SKRYNIA <no-reply@skrynia.com.ua>

# Phone OTP via Twilio Verify (optional — required for wallet withdrawal)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# Used only by `npm test` (Vitest); points at a throwaway database, never the dev one.
TEST_DATABASE_URL=postgres://marketplace:marketplace@localhost:5432/marketplace_test

# Allows POST /payments/test/orders/:id/{success,failure,wait-accept} to run even when
# NODE_ENV=production (e.g. a staging demo). Leave false/unset on real production.
ENABLE_TEST_PAYMENTS=false
