# Used by `docker compose up` to fill in docker-compose.yml.
# Copy to .env and fill in real production values before deploying.

POSTGRES_DB=marketplace
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=change-me-to-a-long-random-postgres-password

JWT_SECRET=change-me-to-a-long-random-production-secret
METRICS_USER=metrics
METRICS_PASSWORD=change-me-to-a-long-random-metrics-password

FRONTEND_URL=https://your-domain.example
PUBLIC_BACKEND_URL=https://api.your-domain.example
NEXT_PUBLIC_API_URL=https://api.your-domain.example
NEXT_PUBLIC_WS_URL=wss://api.your-domain.example/ws

PLATFORM_FEE_BPS=1000
AUTO_RELEASE_HOURS=72
STORAGE_DRIVER=local

# Telegram Login Widget (https://core.telegram.org/widgets/login) - leave unset to disable
TELEGRAM_BOT_TOKEN=

# Resend (https://resend.com) powers email verification and password-reset mail, sent over
# its HTTPS API rather than SMTP - most PaaS hosts (Railway included) block outbound SMTP
# ports, which makes SMTP silently time out regardless of credentials. Without an API key
# the server still starts (a warning is logged), but registration emails silently no-op and
# the explicit resend endpoint returns an error in production. See docs/email-verification.md.
RESEND_API_KEY=
EMAIL_FROM=SKRYNIA <no-reply@skrynia.com.ua>
