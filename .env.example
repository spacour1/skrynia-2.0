# Used by `docker compose up` to fill in docker-compose.yml.
# Copy to .env and fill in real production values before deploying.

POSTGRES_DB=marketplace
POSTGRES_USER=marketplace
POSTGRES_PASSWORD=change-me-to-a-long-random-postgres-password

JWT_SECRET=change-me-to-a-long-random-production-secret
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
TWO_FACTOR_ENCRYPTION_KEY=replace-with-64-hexadecimal-characters
TWO_FACTOR_ENCRYPTION_KEY_VERSION=1
METRICS_USER=metrics
METRICS_PASSWORD=change-me-to-a-long-random-metrics-password

# Persistent-login tuning — defaults keep users signed in for 90 days.
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=90
SESSION_REMEMBER_ME_DAYS=90
REFRESH_ROTATION_ENABLED=true

FRONTEND_URL=https://your-domain.example
PUBLIC_BACKEND_URL=https://api.your-domain.example
NEXT_PUBLIC_API_URL=https://api.your-domain.example
NEXT_PUBLIC_WS_URL=wss://api.your-domain.example/ws
# Set true only when a cross-origin production WS endpoint intentionally authenticates
# with cookies instead of one-time tickets.
# NEXT_PUBLIC_WS_COOKIE_FALLBACK=false

PLATFORM_FEE_BPS=1000
AUTO_RELEASE_HOURS=72

# PostgreSQL pool — see docs/pgbouncer.md for sizing guidance.
# Warning: backend_instances × PG_POOL_MAX must be < PostgreSQL max_connections.
# Recommended with PgBouncer: 5–10. Direct connections: 10–20.
PG_POOL_MAX=20

# Storage: "local" (single-replica only) or "s3" (Cloudflare R2 or AWS S3).
# Multi-replica production MUST use s3 — local uploads are node-local, not shared.
STORAGE_DRIVER=local
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=skrynia-uploads
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Job worker — set false on API-only replicas; run exactly one dedicated worker replica.
# In docker-compose.yml the worker service overrides this to true.
JOB_WORKER_ENABLED=false

# Reverse-proxy trust — set to 1 behind Railway / Fly / Cloudflare.
# Without it, all traffic shares one rate-limit bucket (proxy IP = all users).
TRUST_PROXY=1

# Rate limits (Redis-backed when REDIS_URL is configured).
# PUBLIC_READ_RATE_LIMIT_PER_MIN=600
# ANONYMOUS_WRITE_RATE_LIMIT_PER_MIN=60
# CREDENTIAL_RATE_LIMIT_PER_15MIN=20
# CREDENTIAL_RATE_LIMIT_PER_IDENTITY_15MIN=20
# AUTHENTICATED_WRITE_RATE_LIMIT_PER_MIN=60
# AUTHENTICATED_WRITE_RATE_LIMIT_PER_IP=300
# WS_TICKET_RATE_LIMIT_PER_MIN=30
# WS_TICKET_RATE_LIMIT_PER_IP=120
# WS_MAX_BUFFERED_BYTES=1048576
# WS_MAX_ROOMS_PER_CONNECTION=50
# PHONE_OTP_RATE_LIMIT_PER_15MIN=10
# PHONE_OTP_RATE_LIMIT_PER_IP_15MIN=30
# EMAIL_VERIFICATION_RATE_LIMIT_PER_15MIN=10
# EMAIL_VERIFICATION_RATE_LIMIT_PER_IP_15MIN=30
# PASSWORD_RESET_RATE_LIMIT_PER_15MIN=10
# PASSWORD_RESET_RATE_LIMIT_PER_IP_15MIN=30
# WEBHOOK_RATE_LIMIT_PER_MIN=60

# Redis — required for session revocation, job queue (BullMQ), and caching.
# Without Redis: sessions are not revocable, background jobs do not run.
REDIS_URL=redis://localhost:6379

# Sentry error tracking — leave unset to disable.
# SENTRY_DSN=https://<key>@<host>/0
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog (frontend analytics — set in frontend build environment, not here)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Telegram — same bot token backs both the Telegram Login Widget and the notification
# bot (deep-link account linking + order/dispute/payout/security alerts over Telegram).
# Leave TELEGRAM_BOT_TOKEN unset to disable both. See docs/telegram-bot.md.
TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=skrynia_bot
# TELEGRAM_WEBHOOK_SECRET=

# Resend email API — server starts without it but registration emails silently no-op.
RESEND_API_KEY=
EMAIL_FROM=SKRYNIA <no-reply@skrynia.com.ua>

# Twilio Verify (phone OTP — required for wallet withdrawal)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=
