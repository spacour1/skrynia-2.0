# Read by next.config.mjs's rewrite (Next.js itself proxies /api/* to this address) —
# correct as localhost:4000 only when running `npm run dev` directly on the host. Under
# docker-compose, the frontend service's `environment:` block overrides this to
# http://backend:4000, since the Next.js server then runs inside its own container and
# can't reach the backend container via "localhost".
NEXT_PUBLIC_API_URL=http://localhost:4000
# Used directly by the browser to open a WebSocket — always the host-facing address.
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# Public, canonical URL of the deployed frontend itself — used for metadataBase, the
# sitemap, and absolute Open Graph URLs. Set to the real domain in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
