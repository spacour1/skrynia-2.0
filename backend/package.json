{
  "name": "marketplace-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node-pg-migrate up --envPath .env",
    "migrate:create": "node-pg-migrate create -j sql",
    "migrate:down": "node-pg-migrate down --envPath .env",
    "seed": "tsx src/db/seed.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@sentry/node": "^8.55.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.5",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.12.0",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "sharp": "^0.34.5",
    "ws": "^8.17.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.8",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "supertest": "^7.2.2",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2",
    "vitest": "^4.1.9"
  }
}
